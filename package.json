{
  "name": "voice-comic-theater",
  "version": "1.0.0",
  "private": true,
  "description": "音声AIでつくる！声つき4コマ劇場 — 小学生向けイベント用 Web アプリ (monorepo)",
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev": "npm run dev --workspace frontend",
    "build": "npm run build --workspace frontend",
    "preview": "npm run preview --workspace frontend",
    "panels": "node frontend/scripts/generate-panels.mjs",
    "backend:dev": "echo 'cd backend && uvicorn app.main:app --reload --host 0.0.0.0 --port 8000'",
    "ngrok:front": "ngrok http 5173",
    "ngrok:back": "ngrok http 8000"
  },
  "engines": {
    "node": ">=18"
  }
}
